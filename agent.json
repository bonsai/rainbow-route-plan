{
  "agent": {
    "id": "rainbow-route-micro-guide",
    "name": "Rainbow Route Micro Guide",
    "version": "0.1.0",
    "description": "QR を読むだけ。最適なエッジを瞬時に提供する移動エージェント。",
    "modes": {
      "default": "audio",
      "available": ["audio", "visual", "tactile", "text"],
      "auto_fallback": true
    },
    "tracking": {
      "method": "edge_inference",
      "walk_speed_mps": 1.2,
      "confirm_at_arrival": true,
      "recalc_on_deviation": true
    },
    "speech": {
      "lang": "ja-JP",
      "rate": 0.9,
      "pitch": 1.0,
      "templates": {
        "edge_start": "${direction}に進みます。${distance}メートルです。${notes}",
        "edge_level_change": "${elevator_label}で${to_level}へ移動します。",
        "arrival_expected": "${node_label}に到着したと思われます。到着したらQRをスキャンするか、画面をタップしてください。",
        "arrival_confirmed": "${node_label}を確認しました。",
        "destination_reached": "目的地、${label}に到着しました。",
        "route_found": "${from_label}から${to_label}まで${segment_count}区間を案内します。",
        "route_not_found": "経路が見つかりませんでした。別の場所でQRをスキャンしてください。",
        "recalc": "経路を再計算しました。${label}から案内を再開します。",
        "wrong_node": "現在地は経路上の次の地点ではありません。経路を再計算します。"
      },
      "direction_words": ["まっすぐ", "右に", "左に"],
      "progress_bar": "🚶 ${percent}% ${bar} ${label}"
    },
    "user_types": {
      "blind": {
        "label": "視覚障がい者",
        "default_mode": "audio",
        "weights": {
          "wheelchair_false": 9999,
          "robot_caution": 0,
          "wheelchair_easy": 1.0,
          "tactile_block": 0.3,
          "level_change": 20,
          "crowd_high": 100,
          "crowd_medium": 30
        },
        "prefer": ["tactile_block"],
        "avoid": ["stairs", "narrow_width"]
      },
      "wheelchair": {
        "label": "車椅子",
        "default_mode": "audio",
        "weights": {
          "wheelchair_false": 9999,
          "robot_caution": 500,
          "wheelchair_easy": 0.5,
          "tactile_block": 1.0,
          "level_change": 20,
          "crowd_high": 100,
          "crowd_medium": 30
        },
        "prefer": ["wide_width", "gentle_slope"],
        "avoid": ["stairs", "step", "steep_slope"]
      },
      "robot": {
        "label": "ロボット",
        "default_mode": "text",
        "weights": {
          "wheelchair_false": 9999,
          "robot_caution": 500,
          "wheelchair_easy": 1.0,
          "tactile_block": 1.0,
          "level_change": 20,
          "crowd_high": 200,
          "crowd_medium": 50
        },
        "prefer": ["wide_width", "smooth_surface"],
        "avoid": ["stairs", "crowded", "rough_surface"]
      },
      "stroller": {
        "label": "ベビーカー",
        "default_mode": "audio",
        "weights": {
          "wheelchair_false": 9999,
          "robot_caution": 500,
          "wheelchair_easy": 0.6,
          "tactile_block": 1.0,
          "level_change": 30,
          "crowd_high": 100,
          "crowd_medium": 30
        },
        "prefer": ["gentle_slope", "smooth_surface"],
        "avoid": ["stairs", "step", "rough_surface"]
      },
      "suitcase": {
        "label": "スーツケース",
        "default_mode": "audio",
        "weights": {
          "wheelchair_false": 9999,
          "robot_caution": 500,
          "wheelchair_easy": 0.7,
          "tactile_block": 1.0,
          "level_change": 25,
          "crowd_high": 100,
          "crowd_medium": 30
        },
        "prefer": ["smooth_surface"],
        "avoid": ["stairs", "gravel", "rough_surface"]
      },
      "elderly": {
        "label": "高齢者",
        "default_mode": "audio",
        "weights": {
          "wheelchair_false": 9999,
          "robot_caution": 500,
          "wheelchair_easy": 0.8,
          "tactile_block": 1.0,
          "level_change": 30,
          "crowd_high": 150,
          "crowd_medium": 50
        },
        "prefer": ["gentle_slope", "rest_area"],
        "avoid": ["stairs", "crowded", "long_distance"]
      }
    }
  },

  "graph": {
