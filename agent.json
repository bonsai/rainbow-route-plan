      { "id": "TOILET-WC-E",  "type": "room",   "level": "1F", "label": "多機能トイレ（東）","tier": 4, "props": { "wheelchair": true } },
      { "id": "TOILET-WC-W",  "type": "room",   "level": "1F", "label": "多機能トイレ（西）","tier": 4, "props": { "wheelchair": true } },
      { "id": "TACTILE-E",    "type": "tactile","level": "1F", "label": "東口点字ブロック","tier": 5, "props": { "blind_navigation": "tactile_block" } },
      { "id": "TACTILE-W",    "type": "tactile","level": "1F", "label": "西口点字ブロック","tier": 5, "props": { "blind_navigation": "tactile_block" } },
      { "id": "STAIRS-E",     "type": "stairs", "level": "1F", "label": "東口階段",      "tier": 5, "props": { "wheelchair": false } }
    ],
    "edges": [
