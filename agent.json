      { "id": "e2",  "from": "JR-GATE-W",   "to": "CONCOURSE-W",   "distance_m": 5,  "props": { "wheelchair": "easy", "blind_navigation": "tactile_block", "width_m": 3.0, "surface": "tile" } },
      { "id": "e3",  "from": "CONCOURSE-E", "to": "EXIT-EAST",     "distance_m": 10, "props": { "wheelchair": "easy", "width_m": 3.0 } },
