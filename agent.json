      { "id": "CONCOURSE-W",  "type": "hall",   "level": "1F", "label": "西コンコース",  "tier": 3, "props": { "wheelchair": true, "width_m": 5.0 } },
      { "id": "CONCOURSE-C",  "type": "hall",   "level": "B1F","label": "中央通路",      "tier": 3, "props": { "wheelchair": true, "width_m": 6.0 } },
      { "id": "INFO-E",       "type": "info",   "level": "1F", "label": "東口案内所",    "tier": 4, "props": { "wheelchair": true } },
