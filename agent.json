      "4": { "label": "付加的目的地",    "types": ["info", "room"] },
      "5": { "label": "補助情報",        "types": ["tactile", "stairs", "escalator"] }
    },
    "nodes": [
      { "id": "ELV-JR-E",   "type": "elevator", "level": "1F", "label": "JR東口エレベータ",       "tier": 1, "props": { "wheelchair": true, "robot": true } },
      { "id": "ELV-JR-E-B1",  "type": "elevator", "level": "B1F","label": "JR東口エレベータ（B1）","tier": 1, "props": { "wheelchair": true, "robot": true } },
      { "id": "ELV-JR-E-B2",  "type": "elevator", "level": "B2F","label": "JR東口エレベータ（B2）","tier": 1, "props": { "wheelchair": true, "robot": true } },
      { "id": "ELV-JR-W",   "type": "elevator", "level": "1F", "label": "JR西口エレベータ",       "tier": 1, "props": { "wheelchair": true, "robot": true } },
      { "id": "ELV-JR-W-B1",  "type": "elevator", "level": "B1F","label": "JR西口エレベータ（B1）","tier": 1, "props": { "wheelchair": true, "robot": true } },
      { "id": "ELV-KEIO",   "type": "elevator", "level": "3F", "label": "京王エレベータ",         "tier": 1, "props": { "wheelchair": true } },
      { "id": "ELV-KEIO-2F",  "type": "elevator", "level": "2F", "label": "京王エレベータ（2F）",  "tier": 1, "props": { "wheelchair": true } },
      { "id": "ELV-KEIO-1F",  "type": "elevator", "level": "1F", "label": "京王エレベータ（1F）",  "tier": 1, "props": { "wheelchair": true } },
      { "id": "JR-GATE-E",    "type": "gate",   "level": "1F", "label": "JR東口改札",    "tier": 2, "props": { "wheelchair": true, "robot": true } },
